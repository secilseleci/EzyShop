@{
    ViewData["Title"] = "Order Successful";
    var orderCodes = ViewBag.OrderCodes as List<string>;  
}

<div class="container text-center mt-5">
    <h2 class="text-success fw-bold">🎉 Your Order Has Been Placed! 🎉</h2>
    <p class="text-muted">Thank you for shopping with us. Your order has been successfully created.</p>

    @if (orderCodes != null && orderCodes.Any())
    {
        <h4 class="fw-bold">Your Order Codes:</h4>
        <ul class="list-group list-group-flush">
            @foreach (var orderCode in orderCodes)
            {
                <li class="list-group-item fw-bold">@orderCode</li>
            }
        </ul>
    }

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Shop" class="btn btn-primary px-4">Continue Shopping</a>
        <a asp-controller="Order" asp-action="OrderHistory" class="btn btn-outline-secondary px-4">View My Orders</a>
    </div>
</div>

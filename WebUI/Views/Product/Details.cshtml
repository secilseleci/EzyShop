@model ProductDetailViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Name" />
        </div>
        <div class="col-md-6">
            <h2>@Model.Name</h2>
            <p><strong>Category:</strong> @Model.CategoryName</p>
            <p><strong>Color:</strong> @Model.Color</p>
            <p><strong>Price:</strong> @Model.Price.ToString("C")</p>
            <p><strong>Stock:</strong> @(Model.IsSoldOut ? "Out of Stock" : Model.Stock.ToString())</p>
            <p><strong>Seller:</strong> @Model.ShopName</p>

            <div class="mt-4">
                <button id="addToCartBtn" class="btn btn-primary" data-product-id="@Model.Id" @(Model.IsSoldOut ? "disabled" : "")>
                    <i class="bi bi-cart-plus"></i> Add to Cart
                </button>
                <a href="@Url.Action("Index", "Product")" class="btn btn-outline-secondary ms-2">Back to Shop</a>

            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        window.isUserAuthenticated = '@(User?.Identity?.IsAuthenticated ?? false)'.toLowerCase() === 'true';
    </script>
    <script src="~/js/product-details.js"></script>
}
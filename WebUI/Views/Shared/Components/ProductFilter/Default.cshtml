@model ProductFilterViewModel

<div class="filter-container p-3 shadow-sm bg-light rounded">
    <h5 class="text-center">Filter Products</h5>

    <form id="productFilterForm">
        <!-- Kategori Seçimi -->
        <div class="form-group">
            <label>Category</label>
            <select id="category" class="form-control">
                <option value="">All Categories</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Name">@category.Name</option>
                }
            </select>
        </div>

        <!-- Renk Seçimi -->
        <div class="form-group mt-2">
            <label>Color</label>
            <input type="text" id="color" class="form-control" placeholder="Enter color">
        </div>

        <!-- Fiyat Aralığı -->
        <div class="form-group mt-2">
            <label>Min Price</label>
            <input type="number" id="minPrice" class="form-control">
        </div>
        <div class="form-group mt-2">
            <label>Max Price</label>
            <input type="number" id="maxPrice" class="form-control">
        </div>

        <!-- Ürün Adı -->
        <div class="form-group mt-2">
            <label>Product Name</label>
            <input type="text" id="name" class="form-control" placeholder="Search by name">
        </div>

        <!-- Filtreleme Butonu -->
        <div class="d-grid gap-2 mt-3">
            <button id="filterButton" type="button" class="btn btn-success rounded shadow">
                <i class="bi bi-search"></i> Search
            </button>
            <button id="resetButton" type="button" class="btn btn-secondary rounded shadow">
                <i class="bi bi-x-circle"></i> Reset Filters
            </button>
        </div>

    </form>
</div>

@model IEnumerable<ProductViewModel>

@if (!Model.Any())
{
    <div class="alert alert-warning">No products found matching your criteria.</div>
}
else
{
    <div class="row ">
 
        @foreach (var product in Model)
        {
            <div class="col-md-4  mb-4">
                <div class="card border border-1 border-top rounded">
                        <img src="~/@product.ImageUrl" class="card-img-top rounded"/>
                    <div class="card-body pb-0">
                        <div class="pl-1">
                            <p class="card-title h5 text-dark opacity-75 text-uppercase text-center"><strong>@product.Name</strong></p>
                            <p class="card-title text-warning text-center"><strong>@product.Color</strong></p>
                            <p class="card-title text-warning text-center"><strong>@product.Description</strong></p>
                        </div>

                        <div class="pl-1">
                            <p class="text-dark text-opacity-75 text-center mb-0">
                                <span>
                                    <strong>@product.Price.ToString("c")</strong>
                                </span>
                            </p>
                        </div>
                        <a asp-controller="Home" asp-action="Details" asp-route-productId="@product.Id"
                           class="btn btn-outline-info border border-2 bg-gradient form-control shadow rounded">
                            <b>Details</b>
                        </a>
                    </div>
                </div>

            </div>
        }
        </div>
        
   
}

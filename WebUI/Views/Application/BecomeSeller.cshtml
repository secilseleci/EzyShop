@model SellerApplicationCreateViewModel

@{
    ViewData["Title"] = "Become a Seller";
}

<div class="renderCard">
    <div class="card shadow border-0 rounded offset-2 col-8">
        <div class="card-header">
            <div class="row mt-2 text-center">
                <h2 class="text-info">Sell on EzyShop</h2>
            </div>
        </div>
        <div class="card-body p-0">
            <form method="post" asp-controller="Application" asp-action="BecomeSeller">
                <div class="border p-3">

                    <!-- ✅ Personal Info -->
                    <h4 class="text-primary mb-3">Personal Information</h4>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating py-2 col-12 mb-3">
                                <input asp-for="Name" class="form-control border-0 shadow rounded" required />
                                <label asp-for="Name"></label>
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating py-2 col-12 mb-3">
                                <input asp-for="Surname" class="form-control border-0 shadow rounded" required />
                                <label asp-for="Surname"></label>
                                <span asp-validation-for="Surname" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating py-2 col-12 mb-3">
                                <input asp-for="Email" class="form-control border-0 shadow rounded" />
                                <label asp-for="Email"></label>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating py-2 col-12 mb-3">
                                <input asp-for="ContactBusinessNumber" class="form-control border-0 shadow rounded" />
                                <label asp-for="ContactBusinessNumber"></label>
                                <span asp-validation-for="ContactBusinessNumber" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- ✅ Business Info -->
                    <h4 class="text-primary mt-4 mb-3">Business Information</h4>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating py-2 col-12 mb-3">
                                <input asp-for="ShopName" class="form-control border-0 shadow rounded" maxlength="100" required />
                                <label asp-for="ShopName"></label>
                                <span asp-validation-for="ShopName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating py-2 col-12 mb-3">
                                <input asp-for="TaxNumber" class="form-control border-0 shadow rounded" maxlength="20" />
                                <label asp-for="TaxNumber"></label>
                                <span asp-validation-for="TaxNumber" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="form-floating py-2 col-12 mb-3">
                                <textarea asp-for="ShopAddress" class="form-control border-0 shadow rounded" minlength="10"></textarea>
                                <label asp-for="ShopAddress"></label>
                                <span asp-validation-for="ShopAddress" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="row mt-3 mb-3">
                    <div class="col-6">
                        <button id="submitButton" type="submit" class="form-control btn btn-info shadow rounded">Apply</button>
                    </div>
                    <div class="col-6 d-flex align-items-center">
                        <p class="text-info">Already have an account? <a asp-controller="Account" asp-action="Login">Login here</a></p>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/emailValidation.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}

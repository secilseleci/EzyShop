@model UserViewModel

@{
    ViewData["Title"] = "Add New User";
}

<div class="container mt-4">
    <div class="card shadow border-0 rounded">
        <div class="card-header">
            <h3 class="text-info">Add New User</h3>
        </div>
        <div class="card-body">
            <form asp-action="CreateUser" method="post">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter user name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="Enter user email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Roles" class="form-label">Role</label>
                    <select asp-for="Roles" class="form-select">
                        <option value="Customer">Customer</option>
                        <option value="Seller">Seller</option>
                    </select>
                    <span asp-validation-for="Roles" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="ListUsers" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>

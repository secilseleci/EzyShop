@{
    ViewData["Title"] = "Seller Applications";
}

<div class="container renderCard">
    <div class="card shadow border-0 rounded">
        <div class="card-header">
            <div class="row p-3">
                <div class="col-6">
                    <h2 class="text-info">Seller Applications</h2>
                </div>
                <div class="col-6 text-end">
                    <button class="btn btn-primary shadow rounded filter-btn" data-status="all">
                        <i class="bi bi-list"></i> All
                    </button>
                    <button class="btn btn-info shadow rounded filter-btn" data-status="pending">
                        <i class="bi bi-hourglass-split"></i> Pending
                    </button>
                    <button class="btn btn-success shadow rounded filter-btn" data-status="approved">
                        <i class="bi bi-check-circle"></i> Approved
                    </button>
                    <button class="btn btn-danger shadow rounded filter-btn" data-status="rejected">
                        <i class="bi bi-x-circle"></i> Rejected
                    </button>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div id="sellerApplicationsTable">
                @Html.Partial("_SellerApplicationsTable", Model as List<SellerApplication>)
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sellerApplications.js"></script>
}

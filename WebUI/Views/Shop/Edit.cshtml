@model ShopViewModel


@{
    ViewData["Title"] = "Edit Shop";
}

<div class="renderCard">
    <div class="card shadow border-0 rounded offset-1 col-10">
        <div class="card-header">
            <div class="row p-3">
                <h2 class="text-info">Edit Shop</h2>
            </div>
        </div>
        <div class="card-body p-0">
            <form method="post" asp-controller="Shop" asp-action="Edit" enctype="multipart/form-data">
                <input asp-for="Id" hidden />
                <input asp-for="SellerId" hidden />

                <div class="row">
                    <div class="col-9">
                        <div class="border p-3">

                            <!-- Name (Read-Only) -->
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating py-2 col-12 mb-3">
                                        <input asp-for="Name" class="form-control border-0 shadow rounded" readonly />
                                        <label asp-for="Name" class="ms-0"></label>
                                    </div>
                                </div>
                            </div>

                            <!-- Tax Number (Read-Only) -->
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating py-2 col-12 mb-3">
                                        <input asp-for="TaxNumber" class="form-control border-0 shadow rounded" readonly />
                                        <label asp-for="TaxNumber" class="ms-0"></label>
                                    </div>
                                </div>
                            </div>

                            <!-- Contact Number (Editable) -->
                            <div class="row">
                                <div class="col-md-6">
                                 @*    <div class="form-floating py-2 col-12 mb-3">
                                        <input asp-for="ContactBusinessNumber" class="form-control border-0 shadow rounded" />
                                        <span asp-validation-for="ContactNumber" class="text-danger"></span>
                                        <label asp-for="ContactNumber" class="ms-0"></label>
                                    </div> *@
                                </div>
                            </div>

                            <!-- Address (Editable) -->
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating py-2 col-12 mb-3">
                                        <input asp-for="ShopAddress" class="form-control border-0 shadow rounded" />
                                        <span asp-validation-for="ShopAddress" class="text-danger"></span>
                                        <label asp-for="ShopAddress" class="ms-0"></label>
                                    </div>
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div class="row mt-4">
                                <div class="col-6">
                                    <button type="submit" class="form-control btn btn-warning shadow">Update</button>
                                </div>
                                <div class="col-6">
                                    <a asp-controller="Shop" asp-action="Index" class="form-control btn btn-outline-secondary shadow">Back To List</a>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}
@model ShopViewModel

<div class="container renderCard">
    <div class="card shadow border-0 rounded">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="text-info">My Shop</h2>
            <a asp-action="Edit"  asp-route-sellerId="@Model.SellerId" class="btn btn-primary">
                <i class="bi bi-pencil-square"></i> Update Shop Info
            </a>
        </div>
        <div class="card-body">
            @if (Model != null)
            {
                <table class="table">
                    <tr>
                        <th>Name:</th>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <th>Tax Number:</th>
                        <td>@Model.TaxNumber</td>
                    </tr>
                   @*  <tr>
                        <th>Contact:</th>
                        <td>@Model.ContactNumber</td>
                    </tr> *@
                    <tr>
                        <th>Address:</th>
                        <td>@Model.ShopAddress</td>
                    </tr>
                    <tr>
                        <th>Status:</th>
                        <td>
                           @*  <span class="badge bg-@(Model.Status == "Approved" ? "success" : "warning")">
                                @Model.Status
                            </span> *@
                        </td>
                    </tr>
                </table>

               @*  @if (Model.Status != "Approved")
                {
                    <div class="alert alert-warning">
                        Your shop is pending admin approval. Please wait for confirmation.
                    </div>
                } *@
            }
            else
            {
                <div class="alert alert-info">
                    <h4>You don’t have a shop yet.</h4>
                    <p>Your seller application has been approved, but your shop has not been created yet.</p>
                    <p>Please contact the administrator for further details.</p>
                </div>
            }
        </div>
    </div>
</div>


@{
    ViewData["Title"] = "Application List";
}

<div class="container renderCard">
    <div class="card shadow border-0 rounded">
        <div class="card-header">
            <div class="row p-3">
                <div class="col-6">
                    <h2 class="text-info">Application List</h2>
                </div>
                
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="tblApplication" class="table table-bordered table-striped" style="width:100%">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Shop</th>
                            <th>Address</th>
                            <th>Tax Number</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/application.js"></script>
}